# Testing environment — NEVER touches your development database.
# Laravel loads this when APP_ENV=testing (e.g. php artisan test, --env=testing).
# Sail creates the "testing" database on MySQL init; main DB stays "laravel".

APP_ENV=testing
APP_DEBUG=true

# CRITICAL: Use separate testing database — your "laravel" dev data is never touched
DB_DATABASE=testing

# Same MySQL credentials as dev (Sail uses one MySQL instance, two databases)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=sail
DB_PASSWORD=password

# Faster test runs
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array
