APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Generative editor: persist AI-generated/edited images to tenant storage as Asset (stable URLs).
# Set false to use the legacy same-origin proxy URL (~45 min cache) instead.
EDITOR_GENERATIVE_PERSIST=true
# Max AssetVersion rows per generative layer (metadata.generative_layer_uuid); oldest pruned.
EDITOR_GENERATIVE_MAX_VERSIONS_PER_LAYER=20
# Days to keep lifecycle=orphaned generative AI layer assets before hard delete (daily job).
GENERATIVE_ORPHAN_CLEANUP_DAYS=7
# When true, full generative prompts may be included in AI run metadata/logs (disable for privacy).
AI_LOG_GENERATIVE_PROMPTS=false
# Async video AI insights (config/assets.php video_ai).
# ASSET_VIDEO_AI_ENABLED=true
# Queue video content analysis automatically when a library upload finishes (ProcessAssetJob). Default off — use bulk
# "Generate video insights", the asset drawer retry, or staged publish with "Run AI pipeline" checked.
# ASSET_VIDEO_AI_AUTO_RUN_AFTER_UPLOAD=false
# Show cumulative USD for video AI in the asset drawer (off by default).
# ASSET_VIDEO_AI_SHOW_COST_IN_DRAWER=false

# Notification orchestration (config/notifications.php): in-app + push fan-out. Off by default.
NOTIFICATIONS_ENABLED=false
# OneSignal REST + Web SDK init (server + client). Off by default.
PUSH_NOTIFICATIONS_ENABLED=false
# In OneSignal → Web, allowed origins / site URL must match how users open the app (same scheme + host + TLD as APP_URL).
# Optional: only when the HTML meta tag is missing (e.g. some dev setups). Production should rely on
# ONESIGNAL_APP_ID in Blade — do not set VITE_ONESIGNAL_APP_ID on staging/prod or a stale build can point at the wrong OneSignal app.
# VITE_ONESIGNAL_APP_ID=
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=
# Optional: Organization API key (OneSignal → Organization → Keys & IDs) — for `php artisan onesignal:verify-app` to read chrome_web_origin.
# ONESIGNAL_ORGANIZATION_API_KEY=
# v16 blocks plain http:// unless allowLocalhostAsSecureOrigin is true. Blade sets meta for APP_ENV=local|development or ONESIGNAL_ALLOW_HTTP_LOCAL. For Vite + odd hostnames add:
# ONESIGNAL_ALLOW_HTTP_LOCAL=true
# VITE_ONESIGNAL_ALLOW_HTTP=true
# GET /test-push — OneSignal smoke test for the logged-in user (404 unless local or PUSH_TEST_ROUTE_ENABLED=true).
# PUSH_TEST_ROUTE_ENABLED=false

# Environment Configuration
# APP_ENV controls Vite behavior:
#   - local: Uses Vite dev server, does NOT require manifest.json
#   - staging/production: Requires built assets (public/build/manifest.json)

# Subdomain Configuration
# Set to true to enable company-specific subdomains (e.g., company-name.yourdomain.com)
# Requires proper DNS and web server configuration
SUBDOMAIN_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# User model for auth (full PHP class name). Must exist — never set to "hash", "bcrypt", etc.
# Those are password hashing concerns (see config/hashing.php / HASH_DRIVER), not the User model.
# AUTH_MODEL=App\Models\User

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Admin Logs → Deploy tab: tail of deploy script log (server path; must be readable by PHP)
# ADMIN_DEPLOY_LOG_PATH=/var/www/jackpot/deploy/deploy.log
# ADMIN_DEPLOY_LOG_TAIL_LINES=100

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Testing: Copy to .env.testing with DB_DATABASE=testing so tests never touch your dev DB.
# Sail creates the "testing" database on MySQL init; .env.testing ensures isolation.

SESSION_DRIVER=database
SESSION_LIFETIME=525600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Kill switch (staging/production Horizon): when false, Horizon runs zero workers — no jobs processed, app stays stable.
# QUEUE_WORKERS_ENABLED=false
# Circuit breaker: heavy jobs (images + PDF queues) release every 60s without running — eases load during incidents.
# QUEUE_SAFE_MODE=true

CACHE_STORE=database
# Scheduler: when APP_ENV=staging and scheduler runs only on worker, set SCHEDULER_ENABLED=false on web
# so schedule:run does nothing there; worker keeps true or unset. Scheduler heartbeat uses shared cache
# (CACHE_STORE=redis or database) so web can still see scheduler health.
# SCHEDULER_ENABLED=true
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Staging/production TLS (e.g. ElastiCache in-transit): REDIS_SCHEME=tls
REDIS_SCHEME=tcp
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# ProcessAssetJob: Redis throttle caps how many assets enter the heavy pipeline per window (burst uploads).
# ASSET_PROCESSING_THROTTLE_ENABLED=false
# ASSET_PROCESSING_THROTTLE_KEY=asset-processing
# ASSET_PROCESSING_THROTTLE_PER_TENANT=false
# ASSET_PROCESSING_THROTTLE_MAX=5
# ASSET_PROCESSING_THROTTLE_DECAY=60
# ASSET_PROCESSING_THROTTLE_RELEASE=10
# Presence (online indicator): optional override when running outside Sail
# REDIS_PRESENCE_CONNECTION=presence
# REDIS_PRESENCE_HOST=127.0.0.1

MAIL_MAILER=log
# For real SMTP (SES, SendGrid, Mailtrap, etc.): most hosts require AUTH. Missing or wrong
# MAIL_USERNAME / MAIL_PASSWORD causes Symfony 530 5.7.1 "Authentication required".
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Block automated/system mailables unless true (see docs/email-notifications.md, config/mail.php)
MAIL_AUTOMATIONS_ENABLED=false

# Staging: single verified From domain + per-tenant display name (see config/mail.php tenant_branding)
# MAIL_TENANT_BRANDING_ENABLED=
# MAIL_STAGING_BRAND_FROM_ADDRESS=no-reply@staging-jackpot.velvetysoft.com

# Mailtrap (Email Testing) — Laravel already ships symfony/mailer; point SMTP here. No extra Composer deps.
# MAIL_MAILER=smtp
# Or use mailtrap (same as smtp — see config/mail.php mailers.mailtrap)
# MAIL_MAILER=mailtrap
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=
# MAIL_PASSWORD=

# --- Mailtrap Sending API (MAIL_MAILER=mailtrap-sdk) ---
# Create a token at https://mailtrap.io/api-tokens — without a key you get:
# Symfony IncompleteDsnException: User is not set (the SDK maps the token to the mailer DSN user).
# Use MAILTRAP_API_KEY or MAILTRAP_API_TOKEN (same value; app accepts either).
# MAIL_MAILER=mailtrap-sdk
# MAILTRAP_HOST=send.api.mailtrap.io
# MAILTRAP_API_KEY=
# MAILTRAP_API_TOKEN=
# Sandbox (testing inbox): MAILTRAP_HOST=sandbox.api.mailtrap.io and set MAILTRAP_INBOX_ID from the inbox URL
# MAILTRAP_INBOX_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Storage provisioning (per-tenant buckets): shared | per_company
# Staging/production with IAM jackpot-staging-*: use per_company + jackpot-{env}-{company_slug}
STORAGE_PROVISION_STRATEGY=shared
STORAGE_BUCKET_NAME_PATTERN=jackpot-{env}-{company_slug}
# CORS origins for S3 (default: origin from APP_URL). Comma-separated to override.
# STORAGE_CORS_ORIGINS=https://staging-jackpot.example.com

AWS_USE_PATH_STYLE_ENDPOINT=false

# CloudFront Signed Cookies (OAC private content)
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PATH=storage/keys/cloudfront-private.pem
CLOUDFRONT_COOKIE_EXPIRY_STAGING=3600
CLOUDFRONT_COOKIE_EXPIRY_PRODUCTION=14400
# Admin signed URL TTL (seconds); cache TTL for URLs should be less than this (e.g. 240)
CLOUDFRONT_ADMIN_SIGNED_URL_TTL=300
ASSET_URL_METRICS=false

VITE_APP_NAME="${APP_NAME}"

# Black Forest Labs — editor “Modify image (AI)” (FLUX.2 flex). See config/ai.php `flux`.
# FLUX_API_KEY=

# Vite Dev Server (only used when APP_ENV=local)
# Set to the URL where your Vite dev server is running
VITE_DEV_SERVER_URL=http://localhost:5173

# Storage add-on Stripe price IDs (create in Stripe Dashboard)
# STRIPE_PRICE_STORAGE_50GB=price_xxx
# STRIPE_PRICE_STORAGE_100GB=price_xxx
# STRIPE_PRICE_STORAGE_250GB=price_xxx
# STRIPE_PRICE_STORAGE_500GB=price_xxx

# Studio composition MP4 export: native FFmpeg vs Playwright (default: ffmpeg_native — no browser on workers).
# STUDIO_RENDERING_DRIVER=ffmpeg_native
# STUDIO_RENDERING_FORCE_DRIVER=
# When ffmpeg cannot represent a composition, optionally fall back to canvas if Playwright is enabled:
# STUDIO_RENDERING_BROWSER_FALLBACK_WHEN_UNSUPPORTED=false
# When true, FFmpeg-native export fails if any visible layer cannot be normalized (unknown type, below primary video z, empty text, radial scrim, etc.).
# STUDIO_RENDERING_FAIL_ON_UNSUPPORTED_VISIBLE_LAYERS=true
# Default font for native Studio text (TTF/OTF). If unset or empty, config uses DejaVu on Debian/Ubuntu.
# Laravel Sail: compose.yaml sets this for app/queue containers; Dockerfile installs fonts-dejavu-core.
# For a local .env when using Sail, you can set explicitly (path inside the container):
# STUDIO_RENDERING_DEFAULT_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
# Local cache for tenant font binaries copied from S3/local disks (under storage/app):
# STUDIO_RENDERING_FONT_CACHE_DIR=studio/font-cache
# Comma list of allowed font extensions for native text (no dot):
# STUDIO_RENDERING_ALLOWED_FONT_EXTENSIONS=ttf,otf
# Optional overrides (empty = use studio_video.ffmpeg_binary / ffprobe_binary):
# STUDIO_RENDERING_FFMPEG_BINARY=
# STUDIO_RENDERING_FFPROBE_BINARY=
# STUDIO_RENDERING_WORKSPACE_PARENT=
# STUDIO_RENDERING_TEXT_RASTER_CACHE_SUBDIR=cache/studio-text-raster
# STUDIO_RENDERING_MAX_CANVAS_WIDTH=4096
# STUDIO_RENDERING_MAX_CANVAS_HEIGHT=4096
# STUDIO_RENDERING_MAX_OUTPUT_DURATION_SECONDS=7200
# STUDIO_RENDERING_FFMPEG_TIMEOUT_SECONDS=3600

# Video lanes (Horizon: supervisor-video-light, supervisor-video-heavy). See config/queue.php and docs/environments/PRODUCTION_ARCHITECTURE_AWS.md
# QUEUE_VIDEO_LIGHT_QUEUE=video-light
# QUEUE_VIDEO_HEAVY_QUEUE=video-heavy
# Optional: dedicate Horizon workers for Studio canvas-runtime export (Playwright + frame capture). Empty = same as video-heavy.
# Worker software (Node, npm ci, playwright install, dry-run preflight): docs/environments/PRODUCTION_WORKER_SOFTWARE.md#nodejs--playwright-video-heavy--studio
# QUEUE_VIDEO_HEAVY_STUDIO_CANVAS_QUEUE=video-heavy-studio-canvas
# STUDIO_VIDEO_CANVAS_RUNTIME_EXPORT_ENABLED=false
# STUDIO_VIDEO_CANVAS_EXPORT_RENDER_URL_TTL=120
# Optional: origin (scheme+host) for signing the internal Playwright render URL only. Use when APP_URL is browser-only
# (e.g. http://jackpot.local) but queue workers run in Docker — they must reach the web app (Sail: http://laravel.test).
# STUDIO_VIDEO_CANVAS_EXPORT_SIGNED_URL_ROOT=http://laravel.test
# Optional comma list: rewrite these origins in the export payload to SIGNED_URL_ROOT (e.g. Vite dev host, or https while APP_URL is http).
# STUDIO_VIDEO_CANVAS_EXPORT_PAYLOAD_EXTRA_ORIGINS=http://127.0.0.1:5173,https://jackpot.local
#
# Forge / releases: canvas export needs node_modules on EVERY release — run `npm ci` in the app root in deploy hooks.
# See scripts/forge-studio-npm-ci.sh and docs/environments/PRODUCTION_WORKER_SOFTWARE.md (Zero-downtime / Forge releases).
# STUDIO_VIDEO_CANVAS_EXPORT_DEFAULT_FPS=30
# STUDIO_VIDEO_CANVAS_EXPORT_NODE_BINARY=node
# STUDIO_VIDEO_CANVAS_EXPORT_PLAYWRIGHT_SCRIPT=scripts/studio-canvas-export.mjs
# When canvas Playwright fails in a way that looks like missing Node/Playwright/Chromium or network to the app,
# a row is written to application_error_events (Operations Center → Application errors, category studio_worker_infra).
# Optional throttled email (same alert code + recipient at most once per window):
# STUDIO_WORKER_INFRA_ALERT_EMAIL=
# STUDIO_WORKER_INFRA_ALERT_USE_SITE_OWNER_EMAIL=false
# STUDIO_WORKER_INFRA_ALERT_MAIL_MINUTES=360
# STUDIO_WORKER_INFRA_EVENT_DEDUPE_MINUTES=30
# Max seconds the queue allows for the whole export job (capture + merge + publish). Must be <= Horizon video-heavy worker timeout.
# STUDIO_VIDEO_EXPORT_JOB_TIMEOUT_SECONDS=12600
# STUDIO_VIDEO_CANVAS_EXPORT_CAPTURE_TIMEOUT_SECONDS=7200
# STUDIO_VIDEO_CANVAS_EXPORT_READINESS_TIMEOUT_MS=120000
# (Values under 60s are ignored by scripts/studio-canvas-export.mjs — use at least 60000 for real exports.)
# STUDIO_VIDEO_CANVAS_EXPORT_NAVIGATION_TIMEOUT_MS=120000
# STUDIO_VIDEO_CANVAS_EXPORT_FRAME_SETTLE_MS=50
# STUDIO_VIDEO_CANVAS_EXPORT_DEVICE_SCALE_FACTOR=1
#
# Canvas runtime FFmpeg merge (PNG sequence + base video → MP4)
# STUDIO_VIDEO_CANVAS_RUNTIME_MERGE_TIMEOUT_SECONDS=3600
# STUDIO_VIDEO_CANVAS_RUNTIME_MERGE_X264_PRESET=veryfast
# STUDIO_VIDEO_CANVAS_RUNTIME_MERGE_X264_CRF=23
# STUDIO_VIDEO_CANVAS_RUNTIME_MERGE_PIXEL_FORMAT=yuv420p
# STUDIO_VIDEO_CANVAS_RUNTIME_MERGE_DELETE_PNG_FRAMES_AFTER_SUCCESS=false
# Optional operator-facing note copied into meta_json.canvas_runtime_retention.policy_note
# STUDIO_VIDEO_CANVAS_RUNTIME_RETENTION_POLICY_NOTE=
# HORIZON_VIDEO_LIGHT_MEMORY=512
# HORIZON_VIDEO_LIGHT_WORKER_TIMEOUT=600
# HORIZON_VIDEO_HEAVY_MEMORY=2048
# Must be >= STUDIO_VIDEO_EXPORT_JOB_TIMEOUT_SECONDS (default 12600) for long canvas-runtime MP4 bakes.
# HORIZON_VIDEO_HEAVY_WORKER_TIMEOUT=12600

# Thumbnail / Queue Timeout Hierarchy (staging + production worker)
# Rule: Guard >= Job >= Worker (prevents false timeouts)
# Staging worker (separate machine): use production-grade values below
# QUEUE_WORKER_TIMEOUT=1800
# Dedicated asset pipeline queue (Horizon supervisor-images). Must match config/horizon.php.
# QUEUE_IMAGES_QUEUE=images
# Large originals (PSD, huge TIFF, etc.) use a separate queue — add supervisor-images-heavy in Horizon (2048MB RAM, long timeout).
# QUEUE_IMAGES_HEAVY_QUEUE=images-heavy
# Files at or above this size (bytes) go to the heavy queue. Default 200MB.
# ASSET_PIPELINE_HEAVY_MIN_BYTES=209715200
# Horizon: memory (MB) and worker timeout (seconds) for images-heavy workers.
# HORIZON_IMAGES_HEAVY_MEMORY=2048
# HORIZON_IMAGES_HEAVY_WORKER_TIMEOUT=1800
# Horizon worker timeout (seconds) for the default images supervisor — raise if large TIFF/video thumbs hit WorkerTimeoutExceeded.
# HORIZON_IMAGES_WORKER_TIMEOUT=1800
# THUMBNAIL_JOB_TIMEOUT_SECONDS=1800
# THUMBNAIL_TIMEOUT_MINUTES=35
# ProcessAssetJob / GenerateThumbnailsJob max attempts. Throttle saturation uses release() — each counts as an attempt.
# Default 64. Staging/production bursts: raise if you still see MaxAttemptsExceededException (e.g. 128).
# ASSET_PIPELINE_JOB_MAX_TRIES=64
# Wall-clock cap for retries (minutes) alongside tries.
# ASSET_PIPELINE_JOB_RETRY_UNTIL_MINUTES=120

# Skip full S3 download + Imagick in FileInspectionService above this size (bytes). Default 150MB. Use 0 to always download.
# ASSET_INSPECT_MAX_FULL_DOWNLOAD_BYTES=157286400
# ProcessAssetJob timeout (seconds); use slightly under Horizon supervisor timeout for the same queue.
# PROCESS_ASSET_JOB_TIMEOUT_SECONDS=290
# PROCESS_ASSET_JOB_TIMEOUT_HEAVY_SECONDS=1780

# Max source file size (bytes) for server-side thumbnails/previews. Larger files skip preview generation gracefully (no endless retries).
# Default 500MB. Production: raise if workers have more RAM, e.g. THUMBNAIL_MAX_SOURCE_BYTES=5368709120
# THUMBNAIL_MAX_SOURCE_BYTES=524288000

# TIFF / large image safety (prevents OOM on 700MB+ TIFFs)
# Max pixel area before degraded mode (preview+thumb only; skip medium/large)
# THUMBNAIL_MAX_PIXELS=200000000

# Canon CR2 / camera RAW thumbnails (Imagick + LibRaw): prefer embedded preview layer; min area (px²) for a “sensible” layer
# THUMBNAIL_CR2_PREFER_SMALLEST_LAYER=true
# THUMBNAIL_CR2_LAYER_MIN_AREA=1600
# Prefer JPEG subimages when IM exposes them (reduces green cast vs full demosaic on some servers)
# THUMBNAIL_CR2_PREFER_EMBEDDED_JPEG=true
# Skip layers larger than this (pixels) when a smaller subimage exists (default 25M)
# THUMBNAIL_CR2_MAX_RAW_DECODE_PIXELS=25000000
# Set true only if camera WB alone looks wrong (some LibRaw builds conflict with camera+auto WB)
# THUMBNAIL_CR2_RAW_AUTO_WB=false

# Sentry AI Error Monitoring (feature-flagged; no API or jobs until enabled)
# On web/staging: set SENTRY_PULL_ENABLED=true and provide org + auth token to run pull job (daily 02:00).
# SENTRY_API_URL=https://sentry.io/api/0
# SENTRY_ORG_SLUG=your-org-slug
# SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_PULL_ENABLED=false
SENTRY_AUTO_HEAL_ENABLED=false
SENTRY_REQUIRE_CONFIRMATION=true
SENTRY_AI_MODEL=gpt-4o-mini
SENTRY_AI_MONTHLY_LIMIT=25
SENTRY_ENVIRONMENT=staging
SENTRY_EMERGENCY_DISABLE=false
# Max issues to pull per run (0 = no cap). Prevents runaway analysis when many issues exist.
SENTRY_PULL_MAX=50
# Estimated USD per analysis for monthly limit pre-check. Override if using different model or rolling average.
# SENTRY_AI_ESTIMATED_COST_PER_ANALYSIS=0.005

# Insights / Usage: illustrative AWS S3 list storage prices (USD per GB-month, first tier) for archived vs active copy.
# See config/insights_storage.php — override if your region or negotiated rates differ.
# INSIGHTS_S3_STANDARD_USD_PER_GB_MO=0.023
# INSIGHTS_S3_STANDARD_IA_USD_PER_GB_MO=0.0125

# Studio Kling (image-to-video). Default: official Kling API (kling.io platform Access Key + Secret Key, JWT to api-singapore.klingai.com).
# KLING_API_KEY=your_access_key
# KLING_SECRET_KEY=your_secret_key
# Optional: other region (default Singapore): KLING_API_BASE_URL=https://api-singapore.klingai.com
# Optional: model id for native: KLING_NATIVE_IMAGE2VIDEO_MODEL=kling-v2-5-turbo
# Per-job internal COGS estimate (USD) for AI admin / finance totals — not a Kling invoice; tune to your account.
# STUDIO_ANIMATION_ESTIMATED_USD_PER_JOB=1.0
# Add for each second beyond base window (align with credits; default base covers 5s).
# STUDIO_ANIMATION_ESTIMATED_USD_PER_EXTRA_SECOND=0.2
# Plan credits (Studio video is priced above lightweight editor AI; tune packs vs COGS).
# STUDIO_ANIMATION_CREDITS_BASE=60
# STUDIO_ANIMATION_CREDITS_PER_EXTRA_SECOND=12
# STUDIO_ANIMATION_BASE_COVERS_SECONDS=5
# Display only: implied USD when valuing credits at list pack price (e.g. $29/500). Does not change billing.
# STUDIO_ANIMATION_LIST_USD_PER_CREDIT=0.058
# Queue list for animation jobs (process/poll/finalize). Empty = auto: `ai` in staging/production; in `local`, your
# default connection's list (usually `default`) so `php artisan queue:work` without --queue processes them. Set `ai`
# if you run a dedicated worker for the AI queue locally.
# STUDIO_ANIMATION_QUEUE=
# Optional headless locked-frame export (command must include {{DOCUMENT_JSON}} and {{OUTPUT_PNG}} placeholders).
# STUDIO_ANIMATION_BROWSER_FRAME_ENABLED=false
# STUDIO_ANIMATION_BROWSER_FRAME_COMMAND=
# STUDIO_ANIMATION_BROWSER_FRAME_TIMEOUT=120
# Drift gate (default off / warn_only). Use block_high or block_any only when policy-ready.
# STUDIO_ANIMATION_DRIFT_GATE_ENABLED=false
# STUDIO_ANIMATION_DRIFT_GATE_MODE=warn_only
# STUDIO_ANIMATION_DRIFT_GATE_SCORE_THRESHOLD=0.15
# Optional Studio webhook HMAC (legacy env name: STUDIO_ANIMATION_FAL_WEBHOOK_SECRET) — not used for direct Kling API calls.
# STUDIO_ANIMATION_FAL_WEBHOOK_SECRET=
# Official Playwright locked-frame: npm ci; npx playwright install --with-deps --dry-run chromium (preflight); npx playwright install --with-deps chromium
# STUDIO_ANIMATION_OFFICIAL_PLAYWRIGHT_ENABLED=false
# STUDIO_ANIMATION_OFFICIAL_PLAYWRIGHT_REQUIRE_HIGH_FI=false
# STUDIO_ANIMATION_OFFICIAL_PLAYWRIGHT_DISABLE_LEGACY=false
# STUDIO_ANIMATION_OFFICIAL_PLAYWRIGHT_SCRIPT=
# STUDIO_ANIMATION_OFFICIAL_PLAYWRIGHT_NODE=node
# STUDIO_ANIMATION_OFFICIAL_PLAYWRIGHT_TIMEOUT=120
# Drift quality thresholds + strict admin gate
# STUDIO_ANIMATION_DRIFT_GATE_STRICT=false
# STUDIO_ANIMATION_DRIFT_HIGH_SCORE=0.02
# STUDIO_ANIMATION_DRIFT_MEDIUM_SCORE=0.0
# Structured [sa] logs (render_engine, drift_*, webhook, retry, finalize). Set false only if logs are too noisy.
# STUDIO_ANIMATION_OBSERVABILITY_ENABLED=true
# Duplicate flat metric line ([sa_metric]) for parsers — set false to halve Studio Animation log lines.
# STUDIO_ANIMATION_OBSERVABILITY_METRICS=true
# Adds rollout_diagnostics to GET /app/studio/animations/{id} — use only for staging / manual QA.
# STUDIO_ANIMATION_DIAGNOSTICS_API=false

# Studio Versions (Creative Sets) — generation caps + deterministic E2E (local/testing only).
# STUDIO_CREATIVE_SET_GENERATION_MAX_COLORS=6
# When true, skips generative image edit per item (duplicate + ready). Use with QUEUE_CONNECTION=sync for Playwright.
# STUDIO_GENERATION_FAKE_COMPLETE=false
# Opt-in GET /__e2e__/studio-versions/bootstrap — NEVER enable in production. Requires app env local|testing.
# E2E_STUDIO_VERSIONS_ENABLED=false
# E2E_STUDIO_VERSIONS_TOKEN=
